<idea-plugin require-restart="true">
    <id>com.medusalabs.aiken</id>
    <name>Aiken</name>
    <vendor email="" url="https://github.com/MedusaLabs-cardano">MedusaLabs</vendor>
    <description><![CDATA[
      <p><b>Aiken</b> language support for IntelliJ-based IDEs. Aiken is a modern smart contract language for the Cardano platform.</p>
      <p><b>Features</b></p>
      <ul>
        <li>File types for <code>.ak</code> (Aiken) and <code>.uplc</code> (UPLC)</li>
        <li>Syntax highlighting</li>
        <li>Auto-formatting</li>
        <li>Full project indexing and navigation, including <code>std_lib</code></li>
        <li>Sticky lines / breadcrumbs for scope awareness</li>
        <li>Integrated suggestions (completion)</li>
      </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Aiken" language="Aiken" extensions="ak" implementationClass="com.medusalabs.aiken.lang.AikenFileType" fieldName="INSTANCE"/>
        <fileType name="UPLC" language="UPLC" extensions="uplc" implementationClass="com.medusalabs.aiken.lang.UplcFileType" fieldName="INSTANCE"/>

        <lang.syntaxHighlighterFactory language="Aiken" implementationClass="com.medusalabs.aiken.highlight.AikenSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="UPLC" implementationClass="com.medusalabs.aiken.highlight.UplcSyntaxHighlighterFactory"/>

        <lang.parserDefinition language="Aiken" implementationClass="com.medusalabs.aiken.parser.AikenParserDefinition"/>
        <lang.parserDefinition language="UPLC" implementationClass="com.medusalabs.aiken.parser.UplcParserDefinition"/>

        <lang.commenter language="Aiken" implementationClass="com.medusalabs.aiken.comment.AikenCommenter"/>
        <lang.commenter language="UPLC" implementationClass="com.medusalabs.aiken.comment.UplcCommenter"/>

        <lang.refactoringSupport language="Aiken" implementationClass="com.medusalabs.aiken.refactor.AikenRefactoringSupportProvider"/>
        <lang.refactoringSupport language="UPLC" implementationClass="com.medusalabs.aiken.refactor.AikenRefactoringSupportProvider"/>

        <lang.braceMatcher language="Aiken" implementationClass="com.medusalabs.aiken.braces.AikenPairedBraceMatcher"/>
        <lang.braceMatcher language="UPLC" implementationClass="com.medusalabs.aiken.braces.UplcPairedBraceMatcher"/>

        <editorFactoryListener implementation="com.medusalabs.aiken.braces.AikenBraceHighlightingEditorFactoryListener"/>

        <breadcrumbsInfoProvider implementation="com.medusalabs.aiken.breadcrumbs.AikenBreadcrumbsProvider"/>

        <completion.contributor language="Aiken" implementationClass="com.medusalabs.aiken.completion.AikenCompletionContributor"/>
        <completion.contributor language="UPLC" implementationClass="com.medusalabs.aiken.completion.UplcCompletionContributor"/>

        <postStartupActivity implementation="com.medusalabs.aiken.lsp.AikenLspDiagnosticsStartupActivity"/>
        <postStartupActivity implementation="com.medusalabs.aiken.project.AikenGitVcsMappingStartupActivity"/>
        <projectViewNodeDecorator implementation="com.medusalabs.aiken.lsp.AikenProjectViewDiagnosticsDecorator"/>

        <codeInsight.parameterInfo language="Aiken" implementationClass="com.medusalabs.aiken.parameterinfo.AikenParameterInfoHandler"/>

        <renamePsiElementProcessor implementation="com.medusalabs.aiken.rename.AikenRenamePsiElementProcessor"/>

        <findUsagesHandlerFactory implementation="com.medusalabs.aiken.usages.AikenFindUsagesHandlerFactory"/>
        <lang.findUsagesProvider language="Aiken" implementationClass="com.medusalabs.aiken.usages.AikenFindUsagesProvider"/>
        <lang.findUsagesProvider language="UPLC" implementationClass="com.medusalabs.aiken.usages.UplcFindUsagesProvider"/>

        <gotoDeclarationHandler implementation="com.medusalabs.aiken.navigation.AikenGotoDeclarationHandler"/>
        <gotoTargetPresentationProvider implementation="com.medusalabs.aiken.navigation.AikenGotoTargetPresentationProvider" order="first"/>
        <configurationType implementation="com.medusalabs.aiken.run.AikenRunConfigurationType"/>
        <newProjectWizard.languageGenerator implementation="com.medusalabs.aiken.project.AikenNewProjectWizard"/>

        <fileBasedIndex implementation="com.medusalabs.aiken.index.AikenIdentifierIndex"/>
        <fileBasedIndex implementation="com.medusalabs.aiken.index.AikenImportIndex"/>
        <fileBasedIndex implementation="com.medusalabs.aiken.index.AikenFunctionSignatureIndex"/>
        <fileBasedIndex implementation="com.medusalabs.aiken.index.UplcIdentifierIndex"/>

        <indexedRootsProvider implementation="com.medusalabs.aiken.index.AikenBuildIndexableSetContributor"/>

        <lang.foldingBuilder language="Aiken" implementationClass="com.medusalabs.aiken.folding.AikenFoldingBuilder"/>
        <lang.foldingBuilder language="UPLC" implementationClass="com.medusalabs.aiken.folding.UplcFoldingBuilder"/>

        <colorSettingsPage implementation="com.medusalabs.aiken.highlight.AikenColorSettingsPage"/>
        <colorSettingsPage implementation="com.medusalabs.aiken.highlight.UplcColorSettingsPage"/>

        <formattingService implementation="com.medusalabs.aiken.format.AikenFormattingService"/>

        <!-- LSP integration -->
        <platform.lsp.serverSupportProvider implementation="com.medusalabs.aiken.lsp.AikenLspServerSupportProvider"/>
    </extensions>

    <applicationListeners>
        <listener class="com.medusalabs.aiken.format.AikenSaveFormatter"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>
</idea-plugin>
