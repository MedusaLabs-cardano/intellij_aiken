<idea-plugin xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:noNamespaceSchemaLocation="https://plugins.jetbrains.com/schemas/IDEA_PLUGIN_2_0.xsd">
    <id>com.txpipe.aiken</id>
    <name>Aiken</name>
    <vendor email="" url="https://github.com/MedusaLabs">MedusaLabs</vendor>
    <description><![CDATA[
      Aiken language support for IntelliJ-based IDEs: file types for Aiken (.ak) and UPLC (.uplc),
      syntax highlighting, and Language Server Protocol integration via the Aiken CLI.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <lang.language id="Aiken" implementationClass="com.txpipe.aiken.lang.AikenLanguage"/>
        <lang.language id="UPLC" implementationClass="com.txpipe.aiken.lang.UplcLanguage"/>

        <fileType name="Aiken" language="Aiken" extensions="ak" implementationClass="com.txpipe.aiken.lang.AikenFileType"/>
        <fileType name="UPLC" language="UPLC" extensions="uplc" implementationClass="com.txpipe.aiken.lang.UplcFileType"/>

        <lang.syntaxHighlighterFactory language="Aiken" implementationClass="com.txpipe.aiken.highlight.AikenSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="UPLC" implementationClass="com.txpipe.aiken.highlight.UplcSyntaxHighlighterFactory"/>

        <colorSettingsPage implementationClass="com.txpipe.aiken.highlight.AikenColorSettingsPage"/>
        <colorSettingsPage implementationClass="com.txpipe.aiken.highlight.UplcColorSettingsPage"/>

        <!-- LSP integration -->
        <platform.lsp.serverSupportProvider implementationClass="com.txpipe.aiken.lsp.AikenLspServerSupportProvider"/>
        <platform.lsp.formattingSupport implementationClass="com.txpipe.aiken.lsp.AikenLspFormattingSupport"/>

        <!-- Replace Reformat actions at app init -->
        <applicationInitializedListener implementation="com.txpipe.aiken.actions.AikenReformatInstaller"/>
    </extensions>

    <applicationListeners>
        <listener class="com.txpipe.aiken.format.AikenSaveFormatter"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
        <listener class="com.txpipe.aiken.actions.AikenReformatActionListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
    </applicationListeners>
</idea-plugin>
