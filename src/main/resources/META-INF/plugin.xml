<idea-plugin>
    <id>com.medusalabs.aiken</id>
    <name>Aiken</name>
    <vendor email="" url="https://github.com/MedusaDevelopment">MedusaLabs</vendor>
    <description><![CDATA[
      Aiken language support for IntelliJ-based IDEs: file types for Aiken (.ak) and UPLC (.uplc),
      syntax highlighting, and Language Server Protocol integration via the Aiken CLI.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <lang.language id="Aiken" implementationClass="com.medusalabs.aiken.lang.AikenLanguage"/>
        <lang.language id="UPLC" implementationClass="com.medusalabs.aiken.lang.UplcLanguage"/>

        <fileType name="Aiken" language="Aiken" extensions="ak" implementationClass="com.medusalabs.aiken.lang.AikenFileType"/>
        <fileType name="UPLC" language="UPLC" extensions="uplc" implementationClass="com.medusalabs.aiken.lang.UplcFileType"/>

        <lang.syntaxHighlighterFactory language="Aiken" implementationClass="com.medusalabs.aiken.highlight.AikenSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="UPLC" implementationClass="com.medusalabs.aiken.highlight.UplcSyntaxHighlighterFactory"/>

        <lang.parserDefinition language="Aiken" implementationClass="com.medusalabs.aiken.parser.AikenParserDefinition"/>
        <lang.parserDefinition language="UPLC" implementationClass="com.medusalabs.aiken.parser.UplcParserDefinition"/>

        <lang.pairedBraceMatcher language="Aiken" implementationClass="com.medusalabs.aiken.braces.AikenPairedBraceMatcher"/>
        <lang.pairedBraceMatcher language="UPLC" implementationClass="com.medusalabs.aiken.braces.UplcPairedBraceMatcher"/>

        <completion.contributor language="Aiken" implementationClass="com.medusalabs.aiken.completion.AikenCompletionContributor"/>
        <completion.contributor language="UPLC" implementationClass="com.medusalabs.aiken.completion.UplcCompletionContributor"/>

        <lang.findUsagesProvider language="Aiken" implementationClass="com.medusalabs.aiken.usages.AikenFindUsagesProvider"/>
        <lang.findUsagesProvider language="UPLC" implementationClass="com.medusalabs.aiken.usages.UplcFindUsagesProvider"/>

        <fileBasedIndex implementation="com.medusalabs.aiken.index.AikenIdentifierIndex"/>
        <fileBasedIndex implementation="com.medusalabs.aiken.index.UplcIdentifierIndex"/>

        <indexableSetContributor implementation="com.medusalabs.aiken.index.AikenBuildIndexableSetContributor"/>

        <lang.foldingBuilder language="Aiken" implementationClass="com.medusalabs.aiken.folding.AikenFoldingBuilder"/>
        <lang.foldingBuilder language="UPLC" implementationClass="com.medusalabs.aiken.folding.UplcFoldingBuilder"/>

        <colorSettingsPage implementationClass="com.medusalabs.aiken.highlight.AikenColorSettingsPage"/>
        <colorSettingsPage implementationClass="com.medusalabs.aiken.highlight.UplcColorSettingsPage"/>

        <!-- LSP integration -->
        <platform.lsp.serverSupportProvider implementation="com.medusalabs.aiken.lsp.AikenLspServerSupportProvider"/>
    </extensions>

    <applicationListeners>
        <listener class="com.medusalabs.aiken.format.AikenSaveFormatter"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>
</idea-plugin>
